{
  "name": "smart-queue-teller-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Smart Queue",
  "description": "Smart Queue Teller App — Electron desktop app for staff queue operations",
  "main": "src/main.ts",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 NODE_OPTIONS=--import=tsx electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc && tsc -p tsconfig.node.json && vite build",
    "start": "cross-env NODE_OPTIONS=--import=tsx electron .",
    "pack": "npm run build:web && electron-builder --dir",
    "dist": "npm run build:web && electron-builder",
    "dist:win": "npm run build:web && electron-builder --win nsis",
    "lint": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "stylelint": "^17.4.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.smartqueue.teller",
    "productName": "Smart Queue Teller",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "src/main.ts",
      "src/preload.cjs",
      "package.json",
      "build-resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico"
    }
  }
}
